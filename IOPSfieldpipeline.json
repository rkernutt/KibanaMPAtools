PUT _ingest/pipeline/metrics-system.diskio@custom
{
  "processors": [
    {
      "script": {
        "lang": "painless",
        "source": "if (ctx.system != null && ctx.system.diskio != null) {\n  def d = ctx.system.diskio;\n  if (d.read != null) {\n    def r = d.read;\n    def rt = r.time;\n    def rc = r.count;\n    if (rt != null && rc != null && rt instanceof Number && rc instanceof Number) {\n      double td = ((Number) rt).doubleValue();\n      double cd = ((Number) rc).doubleValue();\n      if (td != 0.0) {\n        r.iops = cd / (td / 1000.0);\n      }\n    }\n  }\n  if (d.write != null) {\n    def w = d.write;\n    def wt = w.time;\n    def wc = w.count;\n    if (wt != null && wc != null && wt instanceof Number && wc instanceof Number) {\n      double twt = ((Number) wt).doubleValue();\n      double cwc = ((Number) wc).doubleValue();\n      if (twt != 0.0) {\n        w.iops = cwc / (twt / 1000.0);\n      }\n    }\n  }\n}",
        "ignore_failure": true
      }
    }
  ]
}
